# Example .env file for mini_transcendence
# Fill in your own secrets and credentials for local development or CI

POSTGRES_USER='postgres_user'
POSTGRES_PASSWORD='your_password_here'
POSTGRES_AUTH_DB='auth_db'
POSTGRES_HISTORY_DB='history_db'
POSTGRES_TOURNAMENT_DB='tournament_db'
POSTGRES_AUTH_HOST='auth_db'
POSTGRES_HISTORY_HOST='history_db'
POSTGRES_TOURNAMENT_HOST='tournament_db'
POSTGRES_PORT='5432'

SECRET_KEY='your_secret_key_here'
SECRET_KEY_HISTORY='your_history_secret_key_here'
SECRET_KEY_TOURNAMENT='your_tournament_secret_key_here'
JWT_ALGO='HS256'

CLOUDFLARE_TUNNEL_TOKEN='your_cloudflare_token_here'

ALERTMANAGER_EMAIL='your_email@example.com'
ALERTMANAGER_PASSWORD='your_email_password_here'

GF_SECURITY_ADMIN_USER='admin'
GF_SECURITY_ADMIN_PASSWORD='admin'
GF_SECURITY_CONTENT_SECURITY_POLICY=false
